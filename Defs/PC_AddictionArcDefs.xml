<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!--
    ═══════════════════════════════════════════════════════════════════════════
    ADDICTION ARC DEFS
    ═══════════════════════════════════════════════════════════════════════════
    Fixed-sequence personal epics triggered when a pawn gains an addiction hediff.
    TryStartAddictionArc matches addictionHediffDef to select the correct arc.
    PC_Arc_Addiction_Chemical is the fallback for any unmatched addiction.

    Arc flow (6 stages):
      opening -> dependency -> social -> withdrawal -> crisis -> choice (climax)
      success: addiction hediff removed, successGrammarRole body resolved
      failure: addiction remains, failureGrammarRole body resolved
    ═══════════════════════════════════════════════════════════════════════════
  -->

  <!-- ── Alcohol ─────────────────────────────────────────────────────────── -->
  <PawnChronicles.PersonalEpicDef>
    <defName>PC_Arc_Addiction_Alcohol</defName>
    <label>The Drunken Master</label>
    <modus>Kindle</modus>
    <stageCount>6</stageCount>
    <addictionHediffDef>AlcoholAddiction</addictionHediffDef>
    <withdrawalHediffDef>AlcoholWithdrawal</withdrawalHediffDef>
    <successGrammarRole>addiction_alcohol_success</successGrammarRole>
    <failureGrammarRole>addiction_alcohol_failure</failureGrammarRole>
    <redeemedEpithet>Sober Reckoning</redeemedEpithet>
    <corruptedEpithet>One for the Road</corruptedEpithet>
    <fixedStageSequence>
      <li>PC_AddStage_Alcohol_Opening</li>
      <li>PC_AddStage_Alcohol_Dependency</li>
      <li>PC_AddStage_Alcohol_Social</li>
      <li>PC_AddStage_Alcohol_Withdrawal</li>
      <li>PC_AddStage_Alcohol_Crisis</li>
      <li>PC_AddStage_Alcohol_Choice</li>
    </fixedStageSequence>
  </PawnChronicles.PersonalEpicDef>

