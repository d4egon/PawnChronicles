      <inspirationChance>0.45</inspirationChance>
    </partnerSuccessOutcome>
    <initiatorFailureOutcome>
      <moodThought>PC_Thought_ArcFail_TooLate</moodThought>
    </initiatorFailureOutcome>
    <partnerFailureOutcome>
      <moodThought>PC_Thought_ArcFail_WeightRemains</moodThought>
    </partnerFailureOutcome>
  </PawnChronicles.EntangledArcDef>

  <!-- ── MENTOR / APPRENTICE ─────────────────────────────────────────────── -->
  <PawnChronicles.EntangledArcDef>
    <defName>PC_Entangled_MentorApprentice</defName>
    <label>The Teaching</label>
    <description>One who has mastered something, and one who hungers for it. The gap between them is either a bridge or a cliff.</description>
