<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- ═══════════════════════════════════════════════════════════════════════
       ENTANGLED STAGE DEFS
       Each stage is a top-level def referenced by name in the arc's stagePool.
       Opening stages fire first. Middle stages fill the gap. Climax stages end it.
  ═══════════════════════════════════════════════════════════════════════════ -->

  <!-- ───────────────────────────────────────────────────────────────────────
       RIVALRY STAGES
  ─────────────────────────────────────────────────────────────────────────── -->

  <PawnChronicles.EntangledStageDef>
    <defName>PC_EStage_Rivalry_Opening</defName>
    <label>the spark of conflict</label>
    <isOpening>true</isOpening>
    <isMiddle>false</isMiddle>
    <conditionMode>InitiatorOnly</conditionMode>
    <initiatorTagRequirements>
      <li>
        <tag>PC_Tag_Violence</tag>
        <minScore>15</minScore>
        <weight>1.5</weight>
      </li>
    </initiatorTagRequirements>
    <partnerTagRequirements>
      <li>
        <tag>PC_Tag_Duty</tag>
        <minScore>10</minScore>
        <weight>1.0</weight>
      </li>
    </partnerTagRequirements>
  </PawnChronicles.EntangledStageDef>

  <PawnChronicles.EntangledStageDef>
    <defName>PC_EStage_Rivalry_Middle_Escalation</defName>
    <label>the wound between them deepens</label>
    <isMiddle>true</isMiddle>
    <conditionMode>EitherMeets</conditionMode>
    <initiatorTagRequirements>
      <li>
        <tag>PC_Tag_Violence</tag>
        <minScore>15</minScore>
        <weight>1.0</weight>
      </li>
    </initiatorTagRequirements>
  </PawnChronicles.EntangledStageDef>

  <PawnChronicles.EntangledStageDef>
    <defName>PC_EStage_Rivalry_Climax_Confront</defName>
    <label>a reckoning</label>
    <isClimax>true</isClimax>
    <outcomeSetsSuccess>true</outcomeSetsSuccess>
    <conditionMode>BothMustMeet</conditionMode>
    <initiatorTagRequirements>
      <li>
        <tag>PC_Tag_Violence</tag>
        <minScore>15</minScore>
        <weight>1.0</weight>
      </li>
    </initiatorTagRequirements>
  </PawnChronicles.EntangledStageDef>

  <PawnChronicles.EntangledStageDef>
    <defName>PC_EStage_Rivalry_Climax_Collapse</defName>
    <label>the rivalry ends in ruin</label>
    <isClimax>true</isClimax>
    <outcomeSetsSuccess>false</outcomeSetsSuccess>
    <conditionMode>EitherMeets</conditionMode>
    <initiatorTagRequirements>
      <li>
        <tag>PC_Tag_Betrayal</tag>
        <minScore>10</minScore>
        <weight>1.0</weight>
      </li>
    </initiatorTagRequirements>
  </PawnChronicles.EntangledStageDef>

