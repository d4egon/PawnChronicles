  <!-- ═══════════════════════════════════════════════════════════════════════
       ENTANGLED ARC DEFS
  ═══════════════════════════════════════════════════════════════════════════ -->

  <!-- ── RIVALRY ─────────────────────────────────────────────────────────── -->
  <PawnChronicles.EntangledArcDef>
    <defName>PC_Entangled_Rivalry</defName>
    <label>The Rivalry</label>
    <description>Two colonists whose natures put them in opposition. Whether it ends in grudging respect or mutual destruction depends on what they do.</description>
    <arcType>Rivalry</arcType>
    <stageCount>3</stageCount>
    <activationChance>30</activationChance>
    <generationWeight>12</generationWeight>
    <initiatorRequirements>
      <li>
        <tag>PC_Tag_Violence</tag>
        <minScore>20</minScore>
        <weight>2.0</weight>
      </li>
    </initiatorRequirements>
    <partnerRequirements>
      <li>
        <tag>PC_Tag_Duty</tag>
        <minScore>15</minScore>
        <weight>1.5</weight>
      </li>
    </partnerRequirements>
    <stagePool>
      <li>PC_EStage_Rivalry_Opening</li>
      <li>PC_EStage_Rivalry_Middle_Escalation</li>
      <li>PC_EStage_Rivalry_Climax_Confront</li>
      <li>PC_EStage_Rivalry_Climax_Collapse</li>
    </stagePool>
    <!-- Outcomes: applied by EpicOutcomeApplicator when the climax resolves -->
    <initiatorSuccessOutcome>
      <moodThought>PC_Thought_ArcSuccess_Resolved</moodThought>
      <skillGains>
        <li><skill>Melee</skill><xp>18000</xp></li>
        <li><skill>Shooting</skill><xp>6000</xp></li>
      </skillGains>
      <inspirationDef>Inspired_Creativity</inspirationDef>
      <inspirationChance>0.23</inspirationChance>
    </initiatorSuccessOutcome>
    <partnerSuccessOutcome>
      <moodThought>PC_Thought_ArcSuccess_Resolved</moodThought>
      <skillGains>
        <li><skill>Melee</skill><xp>6000</xp></li>
      </skillGains>
    </partnerSuccessOutcome>
    <initiatorFailureOutcome>
      <moodThought>PC_Thought_ArcFail_WeightRemains</moodThought>
    </initiatorFailureOutcome>
    <partnerFailureOutcome>
      <moodThought>PC_Thought_ArcFail_PricePaid</moodThought>
    </partnerFailureOutcome>
  </PawnChronicles.EntangledArcDef>

  <!-- ── ROMANCE ──────────────────────────────────────────────────────────── -->
  <PawnChronicles.EntangledArcDef>
    <defName>PC_Entangled_Romance</defName>
