        <tag>PC_Tag_Kinship</tag>
        <minScore>25</minScore>
        <weight>2.0</weight>
      </li>
    </initiatorRequirements>
    <partnerRequirements>
      <li>
        <tag>PC_Tag_Kinship</tag>
        <minScore>20</minScore>
        <weight>1.5</weight>
      </li>
    </partnerRequirements>
    <stagePool>
      <li>PC_EStage_Romance_Opening</li>
      <li>PC_EStage_Romance_Middle_Distance</li>
      <li>PC_EStage_Romance_Climax_Bond</li>
      <li>PC_EStage_Romance_Climax_Loss</li>
    </stagePool>
    <initiatorSuccessOutcome>
      <moodThought>PC_Thought_ArcSuccess_Restored</moodThought>
      <skillGains>
        <li><skill>Social</skill><xp>18000</xp></li>
      </skillGains>
      <inspirationDef>Inspired_Creativity</inspirationDef>
      <inspirationChance>0.45</inspirationChance>
    </initiatorSuccessOutcome>
    <partnerSuccessOutcome>
      <moodThought>PC_Thought_ArcSuccess_Restored</moodThought>
      <skillGains>
        <li><skill>Social</skill><xp>18000</xp></li>
      </skillGains>
