<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- ═══════════════════════════════════════════════════════════════════════
       EMBER QUEST SCRIPT - lightweight, auto-expires, letter-only
  ═══════════════════════════════════════════════════════════════════════ -->

  <QuestScriptDef>
    <defName>PC_Quest_Ember</defName>
    <expireDaysRange>2~2</expireDaysRange>
    <root Class="QuestNode_Sequence">
      <nodes>
        <li Class="PawnChronicles.QuestNode_EpicStage">
          <signal>PawnEpic_EmberComplete</signal>
          <stageRole>ember</stageRole>
        </li>
      </nodes>
    </root>
  </QuestScriptDef>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOOD BUFF - small reward for completing an ember
  ═══════════════════════════════════════════════════════════════════════ -->

  <!--
    PC_EmberCompleted - stacking "momentum" buff, up to 3 deep.
    Applied each time an ember fires. As moments accumulate across a day or two,
    this creates a rising sense that things have been going right for this pawn.
    Stage index mirrors PC_Thought_EmberMoment: 0=violence, 1=social, 2=craft,
    3=intellectual, 4=wilderness, 5=generic. Applied by TagToStageIndex in C#.
  -->
  <ThoughtDef>
    <defName>PC_EmberCompleted</defName>
    <durationDays>1</durationDays>
    <stackLimit>3</stackLimit>
    <stages>
      <!-- 0: violence -->
      <li>
        <label>running on adrenaline</label>
        <description>The body remembers what it's good at. A run of hard days that went the right way.</description>
        <baseMoodEffect>3</baseMoodEffect>
      </li>
      <!-- 1: social / nurture / healer -->
      <li>
        <label>people have needed me lately</label>
        <description>A string of small moments where being there for others actually mattered. It adds up.</description>
        <baseMoodEffect>3</baseMoodEffect>
      </li>
      <!-- 2: craft -->
      <li>
        <label>the work has been going well</label>
        <description>Several things in a row that came together right. Muscle memory serves me well.</description>
        <baseMoodEffect>3</baseMoodEffect>
      </li>
      <!-- 3: curiosity / intellectual -->
      <li>
        <label>a productive stretch</label>
        <description>The mind has been sharp lately. Problems have been yielding. Questions have been answering themselves.</description>
        <baseMoodEffect>3</baseMoodEffect>
      </li>
      <!-- 4: wilderness / animal -->
      <li>
        <label>the land has been good to me</label>
        <description>A few quiet days where the world outside the walls felt navigable rather than hostile.</description>
        <baseMoodEffect>3</baseMoodEffect>
      </li>
      <!-- 5: generic fallback -->
      <li>
        <label>a small moment</label>
        <description>I took a moment to attend to something personal. It helped.</description>
        <baseMoodEffect>3</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>


  <!-- ═══════════════════════════════════════════════════════════════════════
       NEGATIVE THOUGHT - minor setback during an ember
  ═══════════════════════════════════════════════════════════════════════ -->

  <ThoughtDef>
    <defName>PC_Thought_EmberSetback</defName>
    <durationDays>0.5</durationDays>
    <stackLimit>1</stackLimit>
    <stages>
      <li>
        <label>a small setback</label>
        <description>Something went slightly wrong. Nothing serious, but the day felt a little dimmer for it.</description>
        <baseMoodEffect>-4</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>

